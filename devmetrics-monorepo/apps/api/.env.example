# -----------------------------------------------------------------------------
# Backend Environment Variables (.env)
# Do not store real secrets in this file. Copy to .env and fill in values.
# -----------------------------------------------------------------------------

# Application
PORT=4000
FRONTEND_URL=https://your-production-frontend.vercel.app

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"

# OpenAI API (For AI Insights)
OPENAI_API_KEY="sk-proj-..."

# GitHub OAuth (Create OAuth App in GitHub Developer Settings)
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_WEBHOOK_SECRET="your_webhook_secret_string"
