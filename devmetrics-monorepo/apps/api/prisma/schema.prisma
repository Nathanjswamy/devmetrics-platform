generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  firstName String?
  lastName  String?
  username  String?  @unique
  country   String?
  avatar    String?
  role      String   @default("developer")
  githubId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams             UserTeam[]
  prs               PullRequest[] @relation("PrAuthor")
  authoredReviews   Review[]      @relation("ReviewAuthor")
  reviewComments    ReviewComment[] @relation("ReviewCommentAuthor")
  requestedReviews  RequestedReviewer[]
  commits           Commit[]
  integrations      Integration[]
  authoredIssues    Issue[]       @relation("IssueAuthor")
  assignedIssues    Issue[]       @relation("IssueAssignee")
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   UserTeam[]
  repos     Repository[]
}

model UserTeam {
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
}

model Repository {
  id          String   @id @default(uuid())
  name        String
  url         String
  integration String   @default("github")
  githubId    String?  @unique
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  syncStatus  String   @default("idle") // idle, syncing, error
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prs         PullRequest[]
  commits     Commit[]
  issues      Issue[]
  insights    Insight[]
  score       RepositoryScore?
}

model PullRequest {
  id        String   @id @default(uuid())
  repoId    String
  repo      Repository @relation(fields: [repoId], references: [id])
  
  title     String
  status    String   // open, merged, closed
  url       String
  githubId  String?  @unique
  githubCreatedAt DateTime?

  authorId  String
  author    User     @relation("PrAuthor", fields: [authorId], references: [id])
  
  additions Int      @default(0)
  deletions Int      @default(0)

  createdAt DateTime @default(now())
  mergedAt  DateTime?
  updatedAt DateTime @updatedAt

  commits   Commit[]
  reviews   Review[]
  reviewComments ReviewComment[]
  requestedReviewers RequestedReviewer[]

  @@index([status, mergedAt])
  @@index([githubId])
}

model Commit {
  id        String   @id @default(uuid())
  repoId    String
  repo      Repository @relation(fields: [repoId], references: [id])
  
  message   String
  hash      String   @unique
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  pullRequestId String?
  pullRequest   PullRequest? @relation(fields: [pullRequestId], references: [id])

  createdAt DateTime @default(now())
}

model Integration {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  provider     String   // 'github', 'gitlab', 'jira', 'linear'
  profileId    String?  // GitHub username or ID
  accessToken  String
  refreshToken String?
  connectedAt  DateTime @default(now())
}

model Review {
  id            String   @id @default(uuid())
  githubId      String?  @unique
  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  authorId      String
  author        User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  state         String   // APPROVED, CHANGES_REQUESTED, COMMENTED, DISMISSED
  body          String?
  submittedAt   DateTime?
  createdAt     DateTime @default(now())
}

model ReviewComment {
  id            String   @id @default(uuid())
  githubId      String?  @unique
  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  authorId      String
  author        User     @relation("ReviewCommentAuthor", fields: [authorId], references: [id])
  body          String
  createdAt     DateTime @default(now())
}

model RequestedReviewer {
  id            String   @id @default(uuid())
  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  @@unique([pullRequestId, userId])
}

model Insight {
  id             String   @id @default(uuid())
  title          String
  problem        String?
  impact         String?
  recommendation String
  priority       String   // 'info', 'low', 'medium', 'high', 'critical'
  confidence     Int
  category       String   // e.g., 'security', 'architecture', 'tech_debt', 'testing', 'documentation', 'dependency'
  effort         String?
  expectedOutcome String?
  affectedTeam   String?
  repoId         String?
  repo           Repository? @relation(fields: [repoId], references: [id])
  createdAt      DateTime @default(now())
}

model RepositoryScore {
  id               String   @id @default(uuid())
  repoId           String   @unique
  repo             Repository @relation(fields: [repoId], references: [id])
  projectScore     Int
  securityScore    Int
  architectureScore Int
  testingScore     Int
  documentationScore Int
  dependencyScore  Int
  techDebtScore    Int
  maintainabilityScore Int
  strengths        String   // JSON string array
  weaknesses       String   // JSON string array
  risks            String   // JSON string array
  recommendedActions String // JSON string array
  updatedAt        DateTime @updatedAt
}

model Issue {
  id        String   @id @default(uuid())
  githubId  String?  @unique
  repoId    String
  repo      Repository @relation(fields: [repoId], references: [id])
  number    Int
  title     String
  state     String   // open, closed
  url       String
  body      String?
  labels    String   @default("[]") // JSON string array
  createdAt DateTime @default(now())
  closedAt  DateTime?
  updatedAt DateTime @updatedAt

  authorId  String?
  author    User?    @relation("IssueAuthor", fields: [authorId], references: [id])
  assigneeId String?
  assignee   User?   @relation("IssueAssignee", fields: [assigneeId], references: [id])
}
