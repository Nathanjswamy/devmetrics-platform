# =========================================
# DevMetrics Environment Variables Template
# =========================================

# --- Database (Supabase PostgreSQL) ---
# URI format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres?schema=public"

# --- Security & JWT ---
# Cryptographic secret for signing CSRF tokens
JWT_SECRET="generate-a-secure-random-string-here"

# --- GitHub OAuth App (Production) ---
# Create at: GitHub -> Developer Settings -> OAuth Apps
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_CALLBACK_URL="https://api.devmetrics.io/api/v1/integrations/github/callback"

# --- Routing / Endpoints ---
# Where the backend runs (used for frontend calls)
NEXT_PUBLIC_API_URL="https://api.devmetrics.io"

# Where the frontend runs (used for OAuth redirects from the backend)
FRONTEND_URL="https://devmetrics.io"

# --- AI Intelligence ---
OPENAI_API_KEY="sk-proj-your-key-here"
